{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "delang",
  "main": "worker/index.ts",
  "compatibility_date": "2025-05-01",
  "compatibility_flags": ["nodejs_compat"],
  // No `routes` here on purpose: this committed config is shared and runs fine
  // for `pnpm dev` and `workers.dev` deploys without a custom domain. Put your
  // personal custom-domain route (e.g. delang.eflx.top) in a gitignored
  // `wrangler.personal.jsonc` and deploy with `pnpm deploy:personal`.
  // See README.md > Deployment for details.
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "./dist/client/",
    "binding": "ASSETS",
    "not_found_handling": "single-page-application",
    "run_worker_first": true
  },
  "vars": {
    "GEMINI_MODEL": "gemini-3.1-flash-lite"
  }
}
